{
  "manifest_version": 3,
  "name": "git-sniff Scorecard",
  "version": "1.0.0",
  "description": "Premium git-sniff scorecard running directly on GitHub, querying the local microservice backend.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["https://github.com/*"]
    }
  ],
  "action": {}
}
